upstream daoistic {
    server unix:/run/daoistic/socket fail_timeout=0;
}
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name {{ daoistic_hostname }};
    ssl_certificate /etc/letsencrypt/live/{{ host_hostname }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ host_hostname }}/privkey.pem;
    location / {
        try_files $uri @proxy_to_app;
    }
    location /static/ {
        root /opt/daoistic;
    }
    location @proxy_to_app {
        proxy_pass http://daoistic;
        proxy_redirect off;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
